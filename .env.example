# ─────────────────────────────────────────────
# EagleVision  –  Environment Configuration
# Copy this file to .env and edit as needed
# ─────────────────────────────────────────────

# ── CV Service ────────────────────────────────
VIDEO_SOURCE=data/input.mp4
YOLO_MODEL=yolov8m.pt
FLOW_THRESHOLD=1.5
INACTIVE_THRESHOLD=0.5
TARGET_FPS=15
DISPLAY_LOCAL=false
OUTPUT_VIDEO=data/output.mp4

# ── Kafka ─────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=equipment_events

# ── TimescaleDB ───────────────────────────────
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=eaglevision
DB_USER=eagle
DB_PASSWORD=eagle_secret
